# Keep the build context small and secret-free.
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
tests/
data/
*.sqlite
*.sqlite3
*.db
*.log

# Never ship secrets into an image layer.
.env
.env.*
*.key
*.pem
service-account*.json
credentials*.json
client_secret*.json
*-token.json

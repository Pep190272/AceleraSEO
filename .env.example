# ═══════════════════════════════════════════════════════════════
# AceleraSEO — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────
# Default: local SQLite. For production use Postgres.
DATABASE_URL=sqlite:///./data/aceleraseo.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/aceleraseo

# ── Google APIs (SENSE layer) ────────────────────────────────
# OAuth client for Search Console + GA4 (read-only scopes).
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Path to the downloaded OAuth client_secret JSON (gitignored)
GOOGLE_CLIENT_SECRET_FILE=./client_secret.json
# GA4 property to read (numeric ID, e.g. 123456789)
GA4_PROPERTY_ID=
# GSC site URL (e.g. https://example.com/ or sc-domain:example.com)
GSC_SITE_URL=

# ── IndexNow (ACT layer — instant indexing on Bing/Yandex/etc) ─
# Google does NOT support IndexNow. This covers Bing/Yandex/Naver/Seznam/Yep.
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=https://example.com/<INDEXNOW_KEY>.txt

# ── Market data providers (bring-your-own-key) ───────────────
# At least one is required for keyword volumes / competitor data.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPAPI_KEY=
# Optional: real backlink data via third-party API (no self-hosted index)
AHREFS_API_KEY=

# ── LLM (DECIDE layer — strategy reasoning engine) ───────────
# Provider-agnostic. Pick one.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_API_KEY=
# Or run fully local:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ── Autonomy guardrails (ACT safety) ─────────────────────────
# none = propose only (human approves everything) — recommended default
# limited = auto-apply low-risk actions within caps
# full = autonomous (NOT recommended on production sites)
AUTONOMY_MODE=none
MAX_AUTO_ACTIONS_PER_DAY=0
